{
  "name": "eagle-toolkit",
  "version": "1.0.0",
  "description": "Eagle library tools: bulk image renamer + booru tag merger. Pure Node, no dependencies.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.eagle.toolkit",
    "productName": "Eagle Toolkit",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "files": [
      "main.js",
      "preload.js",
      "lib/**",
      "renderer/**",
      "assets/**"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0"
  }
}
